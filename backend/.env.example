GOOGLE_ROUTES_API_KEY=your_google_routes_api_key_here

# 資料路徑 (預設值通常不需要修改)
ROADS_GPKG_PATH=data/raw/gis_osm_roads_free_1.gpkg
ACCIDENTS_GPKG_PATH=data/raw/accidents_epsg3857.gpkg
GRAPH_FILE_PATH=data/processed/taiwan_graph.pkl
ROADS_GDF_PATH=data/processed/roads_gdf.pkl
RISK_SCORES_PATH=data/processed/risk_scores.json

# 風險權重（依事故類型分別設定，待 VSL 研究後調整）
# A1 = 24小時內死亡；A2 = 受傷 或 24小時後死亡
RISK_A1_DEATH_WEIGHT=3.0
RISK_A1_INJURY_WEIGHT=1.5
RISK_A2_DEATH_WEIGHT=2.0
RISK_A2_INJURY_WEIGHT=1.0
RISK_DECAY_HALF_LIFE_YEARS=3.0
RISK_CLIP_PERCENTILE=99.0
SNAP_TOLERANCE_M=20.0

# 路線參數
LAMBDA_DEFAULT=0.5
MAX_GOOGLE_ALTERNATIVES=2
